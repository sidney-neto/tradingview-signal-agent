# tradingview-agent — environment variables
#
# Copy this file to .env and fill in any keys you want to enable.
# All keys are optional. The engine runs without them — optional overlays
# are silently skipped when their key is absent.
#
#   cp .env.example .env

# ─── CoinGlass (optional) ─────────────────────────────────────────────────────
# Enables perp context overlay: funding rate bias, open interest trend,
# fear & greed index, BTC dominance, altcoin season index.
# Adjusts confidence for pullback_watch and breakout_watch signals.
# Get a key: https://coinglass.com/pricing
COINGLASS_API_KEY=

# ─── CoinGecko (optional) ─────────────────────────────────────────────────────
# Enables market breadth context: top-50 gainers/losers regime (risk_on / risk_off),
# trending coins list. Adjusts confidence for altcoin bullish signals.
# Get a key: https://www.coingecko.com/en/api/pricing
# Tier options: demo (default) | paid
COINGECKO_API_KEY=
COINGECKO_API_TIER=demo

# ─── Bybit (optional) ─────────────────────────────────────────────────────────
# Enables official Bybit V5 perp/futures market context: funding bias, open
# interest trend, long/short crowd ratio, ticker snapshot, instrument metadata.
# All functions below use PUBLIC endpoints — no API key required.
# BYBIT_ENV selects the environment. Default: mainnet.
# BYBIT_BASE_URL overrides the base URL (useful for proxies or mock servers).
BYBIT_ENV=mainnet
# BYBIT_BASE_URL=
# BYBIT_TIMEOUT_MS=10000

# ─── TradingView session (optional) ───────────────────────────────────────────
# Only required if you need authenticated TradingView features
# (premium indicators, private charts, etc.).
# Standard market data (OHLCV, symbol search) works without authentication.
# SESSION=
# SIGNATURE=

# ─── Webhook (optional) ───────────────────────────────────────────────────────
# Required to enable the POST /webhook/tradingview endpoint.
# Set a strong random value (e.g. openssl rand -hex 32).
# TRADINGVIEW_WEBHOOK_SECRET=

# Webhook-specific rate limiting (independent from /analyze rate limiting).
# WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
# WEBHOOK_RATE_LIMIT_MAX_REQUESTS=10

# Suppress duplicate TradingView alerts received within this window.
# Set to 0 to disable de-duplication.
# WEBHOOK_DEDUP_TTL_MS=10000

# ─── Delivery layer (optional) ────────────────────────────────────────────────
# Sends webhook-triggered analysis to Telegram and/or OpenClaw.
# Set DELIVERY_ENABLED=true to activate. Delivery failure is non-fatal.

# Enable delivery and choose providers (comma-separated: telegram, openclaw, or both)
# DELIVERY_ENABLED=false
# DELIVERY_PROVIDER=telegram
# DELIVERY_TIMEOUT_MS=5000

# Telegram — requires a bot created via @BotFather
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# OpenClaw — HTTP endpoint that receives structured analysis JSON
# OPENCLAW_DELIVERY_URL=
# OPENCLAW_API_KEY=
# OPENCLAW_SEND_FULL_ANALYSIS=false

# ─── API server ───────────────────────────────────────────────────────────────
# PORT=3000
# LOG_LEVEL=info
# API_KEY=
# DISABLE_AUTH=
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=20
